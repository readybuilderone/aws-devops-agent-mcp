#!/bin/bash
#
# DevOps Agent MCP - Token配置文件
#
# 使用说明:
# 1. 复制此文件: cp token-config.sh.example token-config.sh
# 2. 填写下面的配置值
# 3. 在 .mcp.json 中配置 headersHelper 指向 scripts/get-headers.sh
#
# get-headers.sh 会在每次MCP连接时读取本文件、自动获取并缓存token。
# 无需 HASH_KEY，无需手动注入 ~/.claude/.credentials.json，无需cron，无需重启。
#
# 如何获取这些值? 参考 QUICKSTART.md
#

# Cognito Client ID (从CDK输出的ClientId获取)
CLIENT_ID="your-client-id-here"

# Cognito Client Secret (从aws cognito-idp describe-user-pool-client获取)
CLIENT_SECRET="your-client-secret-here"

# Token Endpoint (从CDK输出的TokenEndpoint获取)
TOKEN_ENDPOINT="https://xxxxx.auth.us-west-2.amazoncognito.com/oauth2/token"

# OAuth Scopes (从CDK输出或 aws cognito-idp list-resource-servers 获取)
SCOPE="DevOpsAgentMcpStack-Gateway-XXXXXXXX/read DevOpsAgentMcpStack-Gateway-XXXXXXXX/write"
